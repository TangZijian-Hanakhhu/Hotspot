# DailyHotApi 自部署地址 (Vercel / Cloudflare Workers)
# 部署指引: https://github.com/imsyy/DailyHotApi
DAILYHOT_BASE_URL=https://api-hot.imsyy.top

# LLM Provider (anthropic | openai | github-copilot | openrouter | deepseek | volcano)
LLM_PROVIDER=volcano

# 火山方舟 Ark (volcano) - OpenAI 兼容编程套餐端点
# 默认 base: https://ark.cn-beijing.volces.com/api/coding/v3
ARK_API_KEY=
ARK_MODEL=doubao-seed-2.0-pro
# ARK_BASE_URL=   # 可选，覆盖默认端点

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# GitHub (用于创建 Issue 和关闭过期 Issue)
GITHUB_TOKEN=
DIGEST_REPO=

# Telegram 通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@popular_radar

# 飞书通知 (逗号分隔多个 webhook)
FEISHU_WEBHOOK_URLS=

# Web UI / RSS 基础地址
PAGES_URL=https://your-username.github.io/popular-radar
